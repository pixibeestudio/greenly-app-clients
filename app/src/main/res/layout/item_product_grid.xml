<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#EAEAEA"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp">

        <!-- Ảnh sản phẩm -->
        <ImageView
            android:id="@+id/ivProductImage"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:background="#F5F5F5"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Overlay Bán hết -->
        <FrameLayout
            android:id="@+id/layoutSoldOut"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#66FFFFFF"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/ivProductImage"
            app:layout_constraintEnd_toEndOf="@id/ivProductImage"
            app:layout_constraintStart_toStartOf="@id/ivProductImage"
            app:layout_constraintTop_toTopOf="@id/ivProductImage">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_sold_out"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Bán hết"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Nhãn giảm giá -->
        <TextView
            android:id="@+id/tvDiscountBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_discount"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="-15%" />

        <!-- Nút Yêu thích -->
        <ImageView
            android:id="@+id/ivFavorite"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_circle_white_shadow"
            android:padding="7dp"
            android:src="@drawable/ic_favorite_border"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#9E9E9E" />

        <!-- Layout Nguồn gốc & Đánh giá -->
        <LinearLayout
            android:id="@+id/llOriginRating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivProductImage">

            <!-- Icon Location -->
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location_on"
                app:tint="#9E9E9E" />

            <!-- Text Nguồn gốc -->
            <TextView
                android:id="@+id/tvProductOrigin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                tools:text="Mộc Châu Farm" />

            <!-- Icon Star -->
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_star"
                app:tint="#FFC107" />

            <!-- Text Đánh giá -->
            <TextView
                android:id="@+id/tvProductRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="4.9" />
        </LinearLayout>

        <!-- Tên sản phẩm -->
        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="#1A3B2A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llOriginRating"
            tools:text="Dâu Tây Mộc Châu" />

        <!-- Nút Thêm vào giỏ -->
        <ImageView
            android:id="@+id/btnAddCart"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_rounded_green_add"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_add"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvProductName"
            app:tint="#FFFFFF" />

        <!-- Layout Giá sản phẩm (Xếp chồng) -->
        <LinearLayout
            android:id="@+id/llPriceContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/btnAddCart"
            app:layout_constraintEnd_toStartOf="@id/btnAddCart"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnAddCart">

            <!-- Giá gốc (Bị gạch ngang) -->
            <TextView
                android:id="@+id/tvProductOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                tools:text="200.000đ" />

            <!-- Layout Giá KM & Đơn vị -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">
                
                <!-- Giá hiện tại / Khuyến mãi -->
                <TextView
                    android:id="@+id/tvProductDiscountPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2E5948"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="180.000đ" />

            </LinearLayout>
            <!-- Đơn vị -->
            <TextView
                android:id="@+id/tvProductUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:paddingBottom="2dp"
                tools:text="/ Hộp 500g" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
