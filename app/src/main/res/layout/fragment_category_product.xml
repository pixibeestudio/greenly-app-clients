<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true"
    tools:context=".ui.fragment.CategoryProductFragment">

    <!-- ==================== HEADER ==================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbarCategoryProduct"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:paddingHorizontal="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Nút Quay lại -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/black" />

        <!-- Tên danh mục -->
        <TextView
            android:id="@+id/tvCategoryTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSearch"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Rau củ quả" />

        <!-- Nút Tìm kiếm -->
        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tìm kiếm"
            android:src="@drawable/ic_search"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/black" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Đường phân cách Header -->
    <View
        android:id="@+id/dividerHeader"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/toolbarCategoryProduct" />

    <!-- ==================== THANH LỌC (FILTER BAR) ==================== -->
    <HorizontalScrollView
        android:id="@+id/svFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerHeader">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Nút Tất cả (Mặc định Active) -->
            <TextView
                android:id="@+id/tvFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filter_active"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Tất cả"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Nút Giá tăng dần -->
            <TextView
                android:id="@+id/tvFilterPriceAsc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Giá ⬆"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Nút Giá giảm dần -->
            <TextView
                android:id="@+id/tvFilterPriceDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Giá ⬇"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Nút Mới nhất -->
            <TextView
                android:id="@+id/tvFilterNewest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Mới nhất"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Nút Bán chạy -->
            <TextView
                android:id="@+id/tvFilterTopSales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Bán chạy"
                android:textColor="@color/black"
                android:textSize="14sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Đường phân cách Filter -->
    <View
        android:id="@+id/dividerFilter"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/svFilters" />

    <!-- ==================== DANH SÁCH SẢN PHẨM ==================== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategoryProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerFilter"
        tools:listitem="@layout/item_product_grid" />

</androidx.constraintlayout.widget.ConstraintLayout>
