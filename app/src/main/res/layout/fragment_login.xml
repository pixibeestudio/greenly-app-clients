<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- 1. Khu vực Thương hiệu (Top-Center) -->
    <LinearLayout
        android:id="@+id/llBrandLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardElevation="6dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/ivLoginLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/logo_welcome_greenly" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvLoginBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Greenly"
            android:textColor="#2E5948"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLoginSlogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ăn sạch, sống lành, nhà nhà đều vui."
            android:textColor="#757575"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 2. Khu vực Ô nhập liệu (Centered Container) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toTopOf="@+id/llActionLogin"
        app:layout_constraintTop_toBottomOf="@+id/llBrandLogin">

        <!-- Cụm nhập Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmailLogin"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#2E5948"
            app:hintEnabled="false"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtEmailLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_email_message"
                android:drawablePadding="12dp"
                android:hint="Nhập email của bạn"
                android:inputType="textEmailAddress"
                android:paddingVertical="16dp"
                android:textColorHint="#9E9E9E" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Quên mật khẩu? -->
        <TextView
            android:id="@+id/tvForgotPasswordDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Quên mật khẩu?"
            android:textColor="#FF5722"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilEmailLogin" />

        <!-- Cụm nhập Mật khẩu -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPasswordLogin"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#2E5948"
            app:hintEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvForgotPasswordDetail">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtPasswordLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_key_lock"
                android:drawablePadding="12dp"
                android:hint="Nhập mật khẩu"
                android:inputType="textPassword"
                android:paddingVertical="16dp"
                android:textColorHint="#9E9E9E" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Nút Toggle Mật khẩu Custom -->
        <ImageView
            android:id="@+id/ivPasswordToggleLogin"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            android:padding="12dp"
            android:src="@drawable/ic_eye_hidden"
            app:layout_constraintBottom_toBottomOf="@id/tilPasswordLogin"
            app:layout_constraintEnd_toEndOf="@id/tilPasswordLogin"
            app:layout_constraintTop_toTopOf="@id/tilPasswordLogin" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 3. Khu vực Hành động (Below Inputs) -->
    <LinearLayout
        android:id="@+id/llActionLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="100dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLoginMain"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#2E5948"
            android:text="Đăng nhập"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <TextView
            android:id="@+id/tvRegisterPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:text="Chưa có tài khoản? Đăng ký ngay"
            android:textColor="#757575"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
