<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Khu vực Thương hiệu (Top-Center) -->
    <LinearLayout
        android:id="@+id/llBrandContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Circular Logo Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:cardCornerRadius="80dp"
            app:cardElevation="8dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/ivWelcomeLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/logo_welcome_greenly"
                tools:srcCompat="@tools:sample/avatars" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Tên Thương hiệu -->
        <TextView
            android:id="@+id/tvWelcomeBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Greenly"
            android:textColor="#2E5948"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Slogan -->
        <TextView
            android:id="@+id/tvWelcomeSlogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Thực phẩm tươi, đời vui tươi."
            android:textColor="#757575"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Khu vực Hành động (Bottom-Center) -->
    <LinearLayout
        android:id="@+id/llActionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Nút Đăng nhập / Đăng ký -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWelcomeLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#2E5948"
            android:text="Đăng nhập / Đăng ký"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <!-- Nút Bắt đầu ngay (Guest) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWelcomeGuest"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Bắt đầu ngay"
            android:textColor="#FFFF"
            android:backgroundTint="#e2725b"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:rippleColor="#33FF5722" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
