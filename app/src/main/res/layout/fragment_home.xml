<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- ===== THANH HEADER CÓ HIỆU ỨNG CUỘN ===== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/header_bg_green"
            app:titleEnabled="false">

            <!-- Container chính của Header: Nền xanh, bo góc 35dp ở đáy, cao 187dp -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutHeaderExpanded"
                android:layout_width="match_parent"
                android:layout_height="187dp"
                android:background="@drawable/header_background"
                android:paddingTop="32dp"
                android:paddingBottom="24dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                app:layout_collapseMode="parallax">

                <!-- 1. Avatar (Top-Start) -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_avatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="Ảnh đại diện"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_default_avatar_placeholder"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- 2. Lời chào và Tên -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/img_avatar"
                    app:layout_constraintEnd_toStartOf="@id/layoutHeaderButtons"
                    app:layout_constraintStart_toEndOf="@id/img_avatar"
                    app:layout_constraintTop_toTopOf="@id/img_avatar">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chào buổi sáng,"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nanthaxay"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 3. Nhóm 2 nút (Top-End) -->
                <LinearLayout
                    android:id="@+id/layoutHeaderButtons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="@id/img_avatar"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/img_avatar">

                    <!-- Nút Yêu thích (Tròn, Solid 10%) -->
                    <ImageButton
                        android:id="@+id/ic_favorite"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/circle_icon_background"
                        android:contentDescription="Yêu thích"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_favorite_border"
                        app:tint="@color/white" />

                    <!-- Nút Thông báo (Tròn, Solid 10%) -->
                    <ImageButton
                        android:id="@+id/ic_notification"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/circle_icon_background"
                        android:contentDescription="Thông báo"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/white" />
                </LinearLayout>

                <!-- 4. Thanh Tìm kiếm (Bottom) -->
                <LinearLayout
                    android:id="@+id/layoutSearch"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/search_bar_background"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_search"
                        app:tint="#757575" />

                    <TextView
                        android:id="@+id/edt_search"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:background="@null"
                        android:hint="Hôm nay bạn muốn nấu gì?..."
                        android:gravity="center_vertical"
                        android:textColor="@color/text_black"
                        android:textColorHint="#9E9E9E"
                        android:textSize="15sp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Sticky Toolbar (Được ghim khi cuộn) -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbarSticky"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_collapseMode="pin"
                app:contentInsetStart="0dp">

                <!-- Giao diện Sticky Header ẩn mặc định -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutHeaderPinned"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:paddingTop="36dp"
                    android:paddingBottom="8dp"
                    android:alpha="0"
                    android:visibility="gone">

                    <!-- Hàng 1: Thanh Tìm kiếm và 2 nút -->
                    <LinearLayout
                        android:id="@+id/row1Sticky"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <LinearLayout
                            android:id="@+id/searchBarSticky"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="40dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_search_bar"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_search"
                                app:tint="#757575" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="8dp"
                                android:background="@null"
                                android:hint="Tìm kiếm sản phẩm..."
                                android:gravity="center_vertical"
                                android:maxLines="1"
                                android:textColor="#333333"
                                android:textColorHint="#9E9E9E"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/ibFavSticky"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="12dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_favorite_border"
                            app:tint="@color/header_bg_green" />

                        <ImageButton
                            android:id="@+id/ibNotifSticky"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_notifications"
                            app:tint="@color/header_bg_green" />
                    </LinearLayout>

                    <!-- Hàng 2: Scroll ngang Filter -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none"
                        app:layout_constraintTop_toBottomOf="@id/row1Sticky"
                        app:layout_constraintStart_toStartOf="parent">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:gravity="center_vertical">

                            <!-- Filter Icon -->
                            <ImageButton
                                android:id="@+id/btnSortIcon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_sort_by_size"
                                app:tint="@color/black" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFilterBy"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lọc theo"
                                android:textColor="@color/black"
                                app:strokeColor="#E0E0E0"
                                app:cornerRadius="16dp"
                                android:layout_marginEnd="8dp"
                                android:minHeight="0dp"
                                android:paddingVertical="4dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCategoryFilter"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loại hàng"
                                android:textColor="@color/black"
                                app:strokeColor="#E0E0E0"
                                app:cornerRadius="16dp"
                                android:layout_marginEnd="8dp"
                                android:minHeight="0dp"
                                android:paddingVertical="4dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDiscountFilter"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ưu đãi"
                                android:textColor="@color/black"
                                app:strokeColor="#E0E0E0"
                                app:cornerRadius="16dp"
                                android:layout_marginEnd="8dp"
                                android:minHeight="0dp"
                                android:paddingVertical="4dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnResetFilter"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reset"
                                android:textColor="@color/header_bg_green"
                                android:minHeight="0dp"
                                android:paddingVertical="4dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </HorizontalScrollView>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ===== NỘI DUNG CUỘN CHÍNH ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- 1. Danh mục (Categories) - Cuộn ngang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:text="Danh mục"
                android:textColor="#1B5E20"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp" />

            <!-- 2. Banner quảng cáo -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp_banner"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp" />

            <!-- Dấu chấm chỉ báo (Indicator) cho Banner -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabIndicator"
                android:layout_width="wrap_content"
                android:layout_height="10dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/tab_indicator_dot"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabIndicatorColor="@android:color/transparent"
                app:tabMaxWidth="8dp"
                app:tabMinWidth="8dp"
                app:tabPaddingStart="3dp"
                app:tabPaddingEnd="3dp"
                app:tabPaddingTop="0dp"
                app:tabPaddingBottom="0dp"
                app:tabRippleColor="@android:color/transparent"/>
            <!-- 3. Sản phẩm mới nhất -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="Sản phẩm mới nhất"
                android:textColor="#1B5E20"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_popular_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp" />

            <!-- 4. Đang giảm giá -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="🔥 Đang giảm giá"
                android:textColor="#E65100"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_discount_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp" />

            <!-- 5. Top 10 bán chạy -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="🏆 Top 10 bán chạy"
                android:textColor="#1B5E20"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_top100_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp" />

            <!-- 6. Tất cả sản phẩm (Grid 2 cột) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="Tất cả sản phẩm"
                android:textColor="#1B5E20"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_all_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
